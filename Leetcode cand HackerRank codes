#LeetCode 
#two sum
class Solution(object):
    def twoSum(self, nums, target):
        n = len(nums)
        for i in range(n):
            for j in range(i + 1, n):
                if nums[i] + nums[j] == target:
                    return [i, j]

#palindrome no.
class Solution:
    def isPalindrome(self, x):
        if x < 0:
            return False
        original = x
        reversed_num = 0
        while x > 0:
            reversed_num = (reversed_num * 10) + (x % 10)
            x //= 10
            
        return reversed_num == original

